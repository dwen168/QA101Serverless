{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...route]"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-news",
      "schedule": "0 22 * * *"
    }
  ]
}
